{
    "name": "ngx-ink",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build --configuration development",
        "build:lib": "ng build ngx-ink-lib && cpx ./README.*md ./dist/ngx-ink",
        "watch": "ng build --watch --configuration development",
        "test": "npm run build && node ./dist/ngx-ink/main.mjs",
        "test:lib": "ng build --configuration test && mocha \"./dist/**/*.spec.mjs\" --enable-source-maps --inspect",
        "postinstall": "patch-package",
        "lint": "eslint --fix ./projects && prettier ./projects --write && eslint --fix ./src && prettier ./src --write"
    },
    "private": true,
    "packageManager": "npm@11.12.1",
    "dependencies": {
        "@alcalzone/ansi-tokenize": "^0.3.0",
        "@angular/common": "^22.0.0",
        "@angular/compiler": "^22.0.0",
        "@angular/core": "^22.0.0",
        "@angular/forms": "^22.0.0",
        "@angular/platform-browser": "^22.0.0",
        "@angular/router": "^22.0.0",
        "ansi-escapes": "^7.3.0",
        "auto-bind": "^5.0.1",
        "chalk": "^5.6.2",
        "cli-boxes": "^4.0.1",
        "cli-cursor": "^5.0.0",
        "code-excerpt": "^4.0.0",
        "es-toolkit": "^1.47.1",
        "indent-string": "^5.0.0",
        "is-in-ci": "^2.0.0",
        "patch-console": "^2.0.0",
        "rxjs": "~7.8.0",
        "signal-exit": "^3.0.7",
        "slice-ansi": "^9.0.0",
        "stack-utils": "^2.0.6",
        "string-width": "^8.2.1",
        "terminal-size": "^4.0.1",
        "tslib": "^2.3.0",
        "type-fest": "^5.7.0",
        "widest-line": "^6.0.0",
        "wrap-ansi": "^10.0.0",
        "yoga-layout": "^3.2.1"
    },
    "devDependencies": {
        "@angular/build": "^22.0.1",
        "@angular/cli": "^22.0.1",
        "@angular/compiler-cli": "^22.0.0",
        "@eslint/js": "^9.32.0",
        "@types/chai": "^5.2.3",
        "@types/jsdom": "^28.0.3",
        "@types/mocha": "^10.0.10",
        "@types/ms": "^2.1.0",
        "@types/node": "^25.9.3",
        "@types/signal-exit": "^3.0.0",
        "@types/sinon": "^21.0.1",
        "@types/stack-utils": "^2.0.3",
        "c8": "^11.0.0",
        "chai": "^6.2.2",
        "cpx": "^1.5.0",
        "delay": "^7.0.0",
        "eslint": "^9.32.0",
        "eslint-plugin-unused-imports": "^4.1.4",
        "fast-glob": "^3.3.3",
        "jsdom": "^28.1.0",
        "mocha": "^11.7.4",
        "ms": "^2.1.3",
        "ng-packagr": "^22.0.0",
        "node-pty": "1.2.0-beta.12",
        "p-queue": "^9.3.0",
        "patch-package": "^8.0.1",
        "prettier": "^3.8.1",
        "sinon": "^22.0.0",
        "tsx": "^4.22.4",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.19.1",
        "vitest": "^4.0.8"
    }
}
